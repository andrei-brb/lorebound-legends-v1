generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FriendshipStatus {
  pending
  accepted
  blocked
}

enum TradeStatus {
  open
  cancelled
  accepted
  expired
}

enum TradeSide {
  from
  to
}

enum ListingStatus {
  open
  cancelled
  fulfilled
  expired
}

enum PvPMatchType {
  async
  live
}

enum PvPMatchStatus {
  pending
  active
  completed
  cancelled
  expired
}

enum GuildInviteStatus {
  pending
  accepted
  declined
  cancelled
}

enum NotificationType {
  friend_request
  friend_accepted
  trade_received
  trade_accepted
  trade_cancelled
  market_listing_sold
  pvp_match_ready
  pvp_live_invite
  pvp_live_result
}

model Player {
  id                         Int                  @id @default(autoincrement())
  discordId                  String               @unique
  username                   String
  avatar                     String?
  gold                       Int                  @default(500)
  stardust                   Int                  @default(0)
  pityCounter                Int                  @default(0)
  totalPulls                 Int                  @default(0)
  lastFreePackTime           DateTime?
  hasCompletedOnboarding     Boolean              @default(true)
  selectedPath               String?
  battlePass                 Json?
  cosmeticsOwned             Json?
  cosmeticsEquipped          Json?
  battlePassXpBoostExpiresAt DateTime?
  deckPresets                Json?
  lastSeenAt                 DateTime?
  guildId                    Int?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  cards                      CardProgress[]
  decks                      Deck[]
  battleStats                BattleStat?
  friendships                Friendship[]         @relation("FriendshipPlayer")
  friendOf                   Friendship[]         @relation("FriendshipFriend")
  outgoingTrades             Trade[]              @relation("TradeFromPlayer")
  incomingTrades             Trade[]              @relation("TradeToPlayer")
  listings                   MarketplaceListing[]
  pvpDeckSnapshots           PvPDeckSnapshot[]
  pvpRatings                 PvPRating[]
  pvpMatchesAsA              PvPMatch[]           @relation("PvPMatchPlayerA")
  pvpMatchesAsB              PvPMatch[]           @relation("PvPMatchPlayerB")
  notifications              Notification[]
  guild                      Guild?               @relation("GuildMembers", fields: [guildId], references: [id], onDelete: SetNull)
  guildOwned                 Guild[]              @relation("GuildOwner")
  chatMessages               ChatMessage[]
  guildInvitesSent           GuildInvite[]        @relation("GuildInviteFrom")
  guildInvitesReceived       GuildInvite[]        @relation("GuildInviteTo")

  @@index([guildId])
  @@index([lastSeenAt])
}

model CardProgress {
  id            Int    @id @default(autoincrement())
  playerId      Int
  cardId        String
  level         Int    @default(1)
  xp            Int    @default(0)
  prestigeLevel Int    @default(0)
  dupeCount     Int    @default(0)
  goldStars     Int    @default(0)
  redStars      Int    @default(0)
  player        Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, cardId])
  @@index([playerId])
}

model Deck {
  id       Int    @id @default(autoincrement())
  playerId Int
  name     String
  cardIds  Json
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}

model BattleStat {
  id           Int       @id @default(autoincrement())
  playerId     Int       @unique
  wins         Int       @default(0)
  losses       Int       @default(0)
  draws        Int       @default(0)
  goldEarned   Int       @default(0)
  lastBattleAt DateTime?
  player       Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model Friendship {
  id             Int              @id @default(autoincrement())
  playerId       Int
  friendPlayerId Int
  status         FriendshipStatus @default(pending)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  player Player @relation("FriendshipPlayer", fields: [playerId], references: [id], onDelete: Cascade)
  friend Player @relation("FriendshipFriend", fields: [friendPlayerId], references: [id], onDelete: Cascade)

  @@unique([playerId, friendPlayerId])
  @@index([playerId])
  @@index([friendPlayerId])
  @@index([status])
}

model Trade {
  id        Int         @id @default(autoincrement())
  status    TradeStatus @default(open)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  fromPlayerId Int
  toPlayerId   Int

  taxGold     Int @default(0)
  taxStardust Int @default(0)

  message String?

  fromPlayer Player      @relation("TradeFromPlayer", fields: [fromPlayerId], references: [id], onDelete: Cascade)
  toPlayer   Player      @relation("TradeToPlayer", fields: [toPlayerId], references: [id], onDelete: Cascade)
  items      TradeItem[]

  @@index([fromPlayerId])
  @@index([toPlayerId])
  @@index([status])
  @@index([createdAt])
}

model TradeItem {
  id       Int       @id @default(autoincrement())
  tradeId  Int
  side     TradeSide
  cardId   String
  quantity Int       @default(1)

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId])
  @@index([cardId])
  @@index([side])
}

model MarketplaceListing {
  id        Int           @id @default(autoincrement())
  status    ListingStatus @default(open)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  sellerPlayerId Int
  seller         Player @relation(fields: [sellerPlayerId], references: [id], onDelete: Cascade)

  taxGold     Int     @default(0)
  taxStardust Int     @default(0)
  note        String?

  items MarketplaceItem[]

  @@index([sellerPlayerId])
  @@index([status])
  @@index([createdAt])
}

model MarketplaceItem {
  id        Int       @id @default(autoincrement())
  listingId Int
  side      TradeSide
  cardId    String
  quantity  Int       @default(1)

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([cardId])
  @@index([side])
}

model PvPDeckSnapshot {
  id          Int      @id @default(autoincrement())
  playerId    Int
  seasonId    String
  deckCardIds Json
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId])
  @@index([seasonId])
}

model PvPRating {
  id          Int      @id @default(autoincrement())
  playerId    Int
  seasonId    String
  mmr         Int      @default(1000)
  rankTier    String   @default("Bronze")
  gamesPlayed Int      @default(0)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, seasonId])
  @@index([seasonId])
  @@index([mmr])
}

model PvPMatch {
  id        Int            @id @default(autoincrement())
  type      PvPMatchType
  status    PvPMatchStatus @default(pending)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  playerAId Int
  playerBId Int

  seasonId String?
  seed     Int?

  // For async matches: stored server result and optional summary
  result Json?

  // For live matches: persisted battle engine state + action log
  state        Json?
  actionLog    Json?
  turnPlayerId Int?
  lastActionAt DateTime?

  playerA Player @relation("PvPMatchPlayerA", fields: [playerAId], references: [id], onDelete: Cascade)
  playerB Player @relation("PvPMatchPlayerB", fields: [playerBId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([status])
  @@index([seasonId])
  @@index([playerAId])
  @@index([playerBId])
  @@index([createdAt])
}

model Notification {
  id        Int              @id @default(autoincrement())
  playerId  Int
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([type])
  @@index([createdAt])
  @@index([readAt])
}

model Guild {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  tag                String   @unique
  description        String?
  ownerPlayerId      Int
  memberCount        Int      @default(1)
  weeklyGoalKey      String   @default("wins")
  weeklyGoalTarget   Int      @default(50)
  weeklyGoalProgress Int      @default(0)
  weeklyResetAt      DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner   Player        @relation("GuildOwner", fields: [ownerPlayerId], references: [id], onDelete: Cascade)
  members Player[]      @relation("GuildMembers")
  invites GuildInvite[]

  @@index([ownerPlayerId])
  @@index([createdAt])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  channel   String // 'global' or 'guild:<id>'
  playerId  Int
  username  String
  avatar    String?
  body      String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([channel, createdAt])
  @@index([playerId])
}

model GuildInvite {
  id           Int               @id @default(autoincrement())
  guildId      Int
  fromPlayerId Int
  toPlayerId   Int
  status       GuildInviteStatus @default(pending)
  createdAt    DateTime          @default(now())
  respondedAt  DateTime?

  guild      Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  fromPlayer Player @relation("GuildInviteFrom", fields: [fromPlayerId], references: [id], onDelete: Cascade)
  toPlayer   Player @relation("GuildInviteTo", fields: [toPlayerId], references: [id], onDelete: Cascade)

  @@unique([guildId, toPlayerId, status])
  @@index([guildId])
  @@index([toPlayerId])
  @@index([status])
  @@index([createdAt])
}
