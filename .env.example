# Discord Developer Portal → your application → OAuth2
# Also add Redirect: https://127.0.0.1 (required placeholder for Activity OAuth)
# Public Application ID (safe to expose in the client bundle)
VITE_DISCORD_CLIENT_ID=

# OAuth2 client secret — server only; never commit real values
DISCORD_CLIENT_SECRET=

# Railway / Node token server only (optional alias for same Application ID)
# DISCORD_CLIENT_ID=

# Public key for verifying Discord interaction signatures (Developer Portal → General → Public Key)
DISCORD_PUBLIC_KEY=

# Bot token (required if you want auto-register on server boot)
DISCORD_BOT_TOKEN=

# Auto-register slash commands on server start (recommended for no-manual setup)
# Set to 1 on Railway. Requires DISCORD_BOT_TOKEN.
AUTO_REGISTER_COMMANDS=

# Optional: register commands to a specific guild for instant updates (dev/staging)
# If unset, registers globally (can take 1-2 minutes to appear).
DISCORD_GUILD_ID=

# Optional: port for server/token-server.mjs (default 3001)
# DISCORD_TOKEN_PORT=3001

# Railway Postgres — provided automatically by Railway Postgres plugin
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Trust X-Forwarded-For for rate-limit keys (set on Railway/reverse proxy only).
# TRUST_PROXY=1

# Rate limits (server/lib/rateLimit.mjs). Set X-Forwarded-For on your reverse proxy (Railway/nginx).
# RATE_LIMIT_INTERACTIONS_PER_MIN=400
# RATE_LIMIT_TOKEN_MAX=25
# RATE_LIMIT_TOKEN_WINDOW_MS=900000
# RATE_LIMIT_API_PER_MIN=900

# Admin allowlist (comma-separated Discord user IDs) for cheat/admin endpoints
# Example: ADMIN_DISCORD_IDS=123456789012345678,987654321098765432
ADMIN_DISCORD_IDS=
