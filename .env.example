# Discord Developer Portal → your application → OAuth2
# Also add Redirect: https://127.0.0.1 (required placeholder for Activity OAuth)
# Public Application ID (safe to expose in the client bundle)
VITE_DISCORD_CLIENT_ID=

# OAuth2 client secret — server only; never commit real values
DISCORD_CLIENT_SECRET=

# Railway / Node token server only (optional alias for same Application ID)
# DISCORD_CLIENT_ID=

# Optional: port for server/token-server.mjs (default 3001)
# DISCORD_TOKEN_PORT=3001
